# 数据存储
DATABASE_URL=sqlite:///./data/solver-web.db

# Redis
REDIS_URL=redis://127.0.0.1:6379/0
TASK_STREAM=solver_tasks
TASK_GROUP=solver_workers
TASK_CONSUMER_NAME=
TASK_READ_COUNT=10
TASK_BLOCK_MS=5000
TASK_STREAM_MAXLEN=20000

# Worker
WORKER_MAX_ATTEMPTS=3
WORKER_RETRY_DELAY_MS=1000

# Solver 节点列表（逗号分隔）
SOLVER_NODE_URLS=http://127.0.0.1:5072
SOLVER_POLL_INTERVAL_MS=250
SOLVER_MAX_WAIT_SECONDS=40
SOLVER_CONNECT_TIMEOUT_MS=2500
SOLVER_READ_TIMEOUT_MS=5000

# 网络设置默认值
DEFAULT_NO_PROXY=localhost,127.0.0.1,::1
NETWORK_SETTINGS_CHANNEL=network_settings_update
NETWORK_SETTINGS_VERSION_KEY=network_settings_version

# API 默认限流
API_DEFAULT_RATE_SECOND=5
API_DEFAULT_RATE_MINUTE=120

# 服务地址
API_HOST=0.0.0.0
API_PORT=8080
ADMIN_HOST=0.0.0.0
ADMIN_PORT=8090

# 管理后台令牌（请求头 X-Admin-Token）
ADMIN_TOKEN=change-me-admin-token

